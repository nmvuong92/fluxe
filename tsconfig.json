{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "erasableSyntaxOnly": true,
    "allowImportingTsExtensions": true,
    "types": ["node"],
    "lib": ["ES2022", "DOM"],
    "paths": {
      "@nmvuong92/fluxe": ["./src/index.ts"],
      "@nmvuong92/fluxe/react": ["./src/react/index.ts"],
      "@nmvuong92/fluxe/client": ["./src/core/client.ts"],
      "@nmvuong92/fluxe/jobs": ["./src/core/jobs.ts"],
      "@nmvuong92/fluxe/auth": ["./src/auth/index.ts"],
      "@nmvuong92/fluxe/express": ["./src/adapters/express.ts"],
      "@nmvuong92/fluxe/fastify": ["./src/adapters/fastify.ts"],
      "@backend/*": ["./app/backend/*"],
      "@frontend/*": ["./app/frontend/*"]
    }
  },
  "include": ["src/**/*", "app/**/*"],
  "exclude": ["docs-site/**", "node_modules"]
}
