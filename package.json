{
  "name": "@nmvuong92/fluxe",
  "version": "0.16.0",
  "description": "fluxe — khung fullstack tối giản, một runtime TS (RCA: Resolved Cell Architecture).",
  "license": "Apache-2.0",
  "author": "nmvuong92",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nmvuong92/fluxe.git"
  },
  "homepage": "https://github.com/nmvuong92/fluxe#readme",
  "bugs": {
    "url": "https://github.com/nmvuong92/fluxe/issues"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./react": {
      "types": "./lib/react/index.d.ts",
      "default": "./lib/react/index.js"
    },
    "./client": {
      "types": "./lib/core/client.d.ts",
      "default": "./lib/core/client.js"
    },
    "./auth": {
      "types": "./lib/auth/index.d.ts",
      "default": "./lib/auth/index.js"
    },
    "./express": {
      "types": "./lib/adapters/express.d.ts",
      "default": "./lib/adapters/express.js"
    },
    "./hono": {
      "types": "./lib/adapters/hono.d.ts",
      "default": "./lib/adapters/hono.js"
    },
    "./nest": {
      "types": "./lib/adapters/nest.d.ts",
      "default": "./lib/adapters/nest.js"
    }
  },
  "files": [
    "lib",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "sync": "tsx scripts/sync.ts",
    "build:client": "npm run sync && esbuild src/client.tsx --bundle --format=esm --outfile=dist/client.js --jsx=automatic --loader:.tsx=tsx",
    "dev": "npm run build:client && node --experimental-sqlite --import tsx scripts/dev.ts",
    "dev:node": "npm run build:client && tsx src/server.tsx",
    "test": "tsx src/selftest2.ts",
    "test:unit": "node --experimental-sqlite --import tsx --test '{src,app}/**/*.test.ts'",
    "test:cells": "node --experimental-sqlite --import tsx --test 'app/cells/**/*.test.ts'",
    "test:all": "npm run sync && npm run typecheck && npm run test:unit && npm run test",
    "resolve": "npm run sync && tsx scripts/resolve.ts",
    "fx": "tsx bin/fx.ts",
    "build": "rm -rf lib && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "release": "npm run test:all && npm version patch -m 'release: v%s' && git push --follow-tags",
    "release:minor": "npm run test:all && npm version minor -m 'release: v%s' && git push --follow-tags",
    "release:major": "npm run test:all && npm version major -m 'release: v%s' && git push --follow-tags"
  },
  "dependencies": {
    "zod": "^3"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "express": "^4 || ^5",
    "hono": "^4",
    "@hono/node-server": "^1 || ^2",
    "@nestjs/common": "^10 || ^11",
    "@nestjs/core": "^10 || ^11"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "@hono/node-server": {
      "optional": true
    },
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.6",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "esbuild": "^0.23",
    "express": "^5.2.1",
    "hono": "^4.12.27",
    "react": "^18",
    "react-dom": "^18",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsx": "^4",
    "typescript": "^5"
  }
}
