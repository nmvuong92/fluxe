{
  "name": "fluxe",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:client": "esbuild src/client.tsx --bundle --format=esm --outfile=dist/client.js --jsx=automatic --loader:.tsx=tsx",
    "dev": "npm run build:client && tsx src/server.tsx",
    "dev:remote": "npm run build:client && FLUXE_BACKEND=remote tsx src/server.tsx",
    "test": "tsx src/selftest2.ts",
    "test:unit": "node --import tsx --test 'src/**/*.test.ts'",
    "test:cells": "node --import tsx --test 'src/cells/**/*.test.ts'",
    "test:all": "npm run test:unit && npm run test",
    "resolve": "tsx scripts/resolve.ts"
  },
  "dependencies": { "react": "^18", "react-dom": "^18", "zod": "^3" },
  "devDependencies": { "typescript": "^5", "tsx": "^4", "esbuild": "^0.23", "@types/node": "^20", "@types/react": "^18", "@types/react-dom": "^18" }
}
